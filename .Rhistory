} else {
jointp_minus_jm_ig <- classes[ig] * exp(sum(loglik[, ig, s])) / exp(loglik[jm, ig, s])
numerator <- n[s] * exp(sum(loglik[, ih, s])) * jointp_minus_jm_ig
denominator <- exp(loglik_case[s])^2
