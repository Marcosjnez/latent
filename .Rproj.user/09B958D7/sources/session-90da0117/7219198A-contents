```{r funciones}
# Target criterion function:

fg <- function(X, f = TRUE, g = FALSE, A, indexes, Target, Weight) {
  
  Inv_X <- solve(X)
  L <- A %*% t(Inv_X)
  
  if(f) { # objective value
    
    f1 <- 0.5*sum(( Weight * (L - Target) )^2)
    
  } else {
    
    f1 <- NULL
    
  }
  
  if(g) {
    
    # gradient:
    g1 <- -t(t(L) %*% (Weight^2 * (L - Target)) %*% Inv_X)
    # Riemannian gradient:
    rg <- projection(g1, X, A, indexes, Target, Weight)
    
  } else {
    
    g1 <- rg <- NULL
    
  }
  
  return(list(f = f1, g = g1, rg = rg))
  
}

symm <- function(X) (X + t(X)) / 2 # returns a symmetric matrix

skew <- function(X) (X - t(X)) / 2 # returns a skew-symmetric matrix

# Column normalization == projection onto the oblique manifold:

retraction_oblq <- function(X) {
  
  X_oblq <- X %*% (diag(1/sqrt(diag(t(X) %*% X))))
  
  return(X_oblq)
  
}

# Projection onto the partially oblique manifold:

retraction_poblq <- function(X, ss, V, A, indexes, Target, Weight) {
  
  X <- X + ss*V
  X <- retraction_oblq(X)
  QR <- qr(X)
  Q <- qr.Q(QR)
  
  I <- length(indexes)-1
  
  # In the following loop, the Gram-Schmidt process is performed between blocks:
  
  if(I == 0) {
    
    X[, -indexes[[1]]] <- Q[, -indexes[[1]]]
    
  } else {
    
    for(i in 1:I) {
      
      cum_indexes <- unlist(indexes[1:i])
      orthogonals <- Q[, cum_indexes, drop = FALSE]
      n <- ncol(orthogonals)
      
      for(j in indexes[[i+1]]) {
        
        A <- cbind(orthogonals, X[, j])
        X[, j] <- gram(A)[, n+1]
        
      }
      
    }
    
    X[, -unlist(indexes)] <- Q[, -unlist(indexes)]
    
  }
  
  return(X)
  
}

# Gram-Schmidt algorithm:

gram <- function(V) {
  
  n <- nrow(V)
  k <- ncol(V)
  U <- matrix(0, n, k)
  U[, 1] <- V[, 1] / sqrt(sum(V[, 1]^2))
  
  for(i in 2:k) {
    
    U[, i] <- V[, i]
    
    for(j in 1:(i-1)) {
      
      U[, i] <- U[, i] - sum(U[, j]*U[, i]) / sum(U[, j]^2) * U[, j]
      
    }
    
    U[, i] <- U[, i] / sqrt(sum(U[, i]^2))
    
  }
  
  return(U)
  
}

# Fix to 0 the off-diagonal elements of the oblique block matrices:

zeros <- function(X, indexes) {
  
  n <- length(indexes)
  X0 <- X
  
  for(i in 1:n) {
    
    X0[indexes[[i]], indexes[[i]]] <- 0
    
  }
  
  diag(X0) <- diag(X)
  
  return(X0)
  
}

# The opposite of zeros:

off <- function(X, indexes) {
  
  Xoff <- matrix(0, nrow(X), ncol(X))
  n <- length(indexes)
  
  for(i in 1:n) {
   
    Xoff[indexes[[i]], indexes[[i]]] <- X[indexes[[i]], indexes[[i]]]
    
  }
  
  diag(Xoff) <- 0
  
  return(Xoff)
  
}

# Solve the Lyapunov equation (Q = YA + AY) for A:

lyapunov <- function(Y, Q) {
  
  q <- nrow(Y)
  I <- diag(1, q)
  Y1 <- kronecker(I, Y)
  Y2 <- kronecker(Y, I)
  X <- Y1 + Y2
  # A and Q are symmetric and some in Q are fixed to 0, so you may solve fewer equations:
  remove_index <- Q != 0 & lower.tri(Q, diag = TRUE)
  Q <- Q[remove_index]
  X <- X[, c(remove_index)][c(remove_index), ]
  Lambda <- solve(X, Q)
  A <- matrix(0, q, q)
  A[remove_index] <- Lambda
  A[upper.tri(A)] <- t(A)[upper.tri(A)]
  
  return(A)
  
}

# Projection onto the tangent space of the partially oblique manifold:

projection_poblq <- function(G, X, A, indexes, Target, Weight) {
  
  X0 <- zeros(t(X) %*% G + t(G) %*% X, indexes)
  Y <- t(X) %*% X
  A <- lyapunov(Y, X0)
  # X0 == Y %*% A + A %*% Y
  N <- X %*% A
  G_proj <- G - N
  
  return(G_proj)
  
}

projection <- projection_poblq
retraction <- retraction_poblq
