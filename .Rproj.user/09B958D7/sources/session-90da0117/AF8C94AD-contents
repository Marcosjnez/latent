mt <- function(iter, ...) {

  iter$old_X <- iter$X
  iter$old_rg <- iter$rg
  phi_0 <- iter$f
  g0 <- sum(iter$rg * iter$dir)

  maxit = 30
  a_max <- 1e4
  delta <- 1.1
  mu <- 0.5; eta <- 0.5
  al <- 0
  au <- 1e3
  at <- 1
  max_iter <- 1

  for(i in 1:max_iter) {

    at <- min(at + delta*(at-al), a_max)
    new_X <- retraction(iter$old_X, at, iter$dir, ...)
    x <- fg(new_X, f = TRUE, g = TRUE, h = FALSE, ...)
    gat <- sum(x$rg * iter$dir)
    phi_at <- x$f
    psi_at <- phi_at - phi_0 - mu*g0*at
    psi_prime_at <- gat - mu*g0

    new_Xl <- retraction(iter$old_X, al, iter$dir, ...)
    phi_al <- fg(new_Xl, f = TRUE, g = FALSE, h = FALSE, ...)$f
    psi_al <- phi_al - phi_0 - mu*g0*al

    U1 <- psi_at > psi_al
    if(U1) {
      al_plus <- al
      au_plus <- at

    }

    U2 <- psi_at <= psi_al & psi_prime_at*(al-at) > 0
    if(U2) {
      al_plus <- at
      au_plus <- au
    }

    U3 <- psi_at <= psi_al & psi_prime_at*(al-at) < 0
    if(U3) {
      al_plus <- at
      au_plus <- al

    }

    al <- al_plus
    au <- au_plus

    iter$a <- at
    iter$X <- new_X
    iter$f <- x$f
    iter$rg <- x$rg

    if(phi_at <= phi_0 + mu*g0*at & abs(gat) <= eta*abs(g0)) {
      break
    }

  }

  return(iter)

}

# Function for minimization:

Roptim <- function(X, search = "zoom",
                   maxit = 1e3, eps = 1e-4,
                   c1 = 0.5, c2 = 0.5, max_inner_iter = 30,
                   a_multiply = 2, a_min = 0.1,
                   algorithm = "L-BFGS", m = 15, ...) {

  options(warn = 1)

  f_g <- fg(X, f = TRUE, g = TRUE, h = FALSE, ...)

  iter <- list()
  iter$X <- X
  iter$f <- f_g$f
  iter$rg <- f_g$rg
  iter$dir <- -iter$rg
  iter$inprod <- sum(iter$rg * -iter$dir)
  iter$ng <- sqrt(iter$inprod)
  iter$a <- 1
  iter$df <- Inf

  p <- length(c(X))
  iter$B <- diag(p)
  iter$H <- diag(p)
  iter$s <- list()
  iter$y <- list()
  iter$p <- list()
  iter$alpha <- list()

  if(search == "back") {

    for (i in 1:maxit) {

      if (iter$inprod < .Machine$double.eps) stop("Wrong direction")
      if (iter$ng < eps | abs(iter$df) < 1e-09) break #

      iter$iterations <- i

      iter <- backtracking(iter, a_multiply, a_min, max_inner_iter,
                           c1, c2, ...)

      if(algorithm == "gradient") {

        iter <- update_gradient(iter, ...)

      } else if(algorithm == "Newton") {

        iter <- update_newton(iter, ...)

      } else if(algorithm == "cg1") {

        iter <- update_cg1(iter, ...)

      } else if(algorithm == "cg2") {

        iter <- update_cg2(iter, ...)

      } else if(algorithm == "cg3") {

        iter <- update_cg3(iter, ...)

      } else if(algorithm == "BFGS") {

        iter <- update_BFGS(iter, ...)

      } else if(algorithm == "L-BFGS") {

        iter$m <- m
        iter <- update_LBFGS(iter, ...)

      } else if(algorithm == "DFP") {

        iter <- update_DFP(iter, ...)

      } else {

        stop("Available algorithms: gradient, Newton, DFP, BFGS, L-BFGS")

      }

      iter$inprod <- sum(iter$rg * -iter$dir)
      iter$ng <- sqrt(iter$inprod)

      cat("Iteration: ", i,
          "f =", iter$f,
          "step size = ", iter$a,
          "ng =", iter$ng, "\r", sep = " ")

    }

  } else if(search == "mt") {

    for (i in 1:maxit) {

      if (iter$inprod < .Machine$double.eps) stop("Wrong direction")
      if (iter$ng < eps | abs(iter$df) < 1e-09) break #

      iter$iterations <- i

      iter <- mt(iter, ...)

      if(algorithm == "gradient") {

        iter <- update_gradient(iter, ...)

      } else if(algorithm == "Newton") {

        iter <- update_newton(iter, ...)

      } else if(algorithm == "cg1") {

        iter <- update_cg1(iter, ...)

      } else if(algorithm == "cg2") {

        iter <- update_cg2(iter, ...)

      } else if(algorithm == "cg3") {

        iter <- update_cg3(iter, ...)

      } else if(algorithm == "BFGS") {

        iter <- update_BFGS(iter, ...)

      } else if(algorithm == "L-BFGS") {

        iter$m <- m
        iter <- update_LBFGS(iter, ...)

      } else if(algorithm == "DFP") {

        iter <- update_DFP(iter, ...)

      } else {

        stop("Available algorithms: gradient, Newton, DFP, BFGS, L-BFGS")

      }

      iter$inprod <- sum(iter$rg * -iter$dir)
      iter$ng <- sqrt(iter$inprod)

      cat("Iteration: ", i,
          "f =", iter$f,
          "step size = ", iter$a,
          "ng =", iter$ng, "\r", sep = " ")

    }

  } else if(search == "zoom") {

    for (i in 1:maxit) {

      if (iter$inprod < .Machine$double.eps) stop("Wrong direction")
      if (iter$ng < eps | abs(iter$df) < 1e-09) break

      iter$iterations <- i

      iter$old_X <- iter$X
      iter$a <- strongBacktracking(fn = fg, iter = iter, alpha=1, beta=c1, sigma= c2, ...)
      iter$X <- retraction(iter$old_X, iter$a, iter$dir, ...)
      new <- fg(iter$X, f = TRUE, g = FALSE, h = FALSE, ...)
      iter$df <- new$f - iter$f
      iter$f <- new$f

      if(algorithm == "gradient") {

        iter <- update_gradient(iter, ...)

      } else if(algorithm == "cg1") {

        iter <- update_cg1(iter, ...)

      } else if(algorithm == "cg2") {

        iter <- update_cg2(iter, ...)

      } else if(algorithm == "cg3") {

        iter <- update_cg3(iter, ...)

      } else if(algorithm == "Newton") {

        iter <- update_newton(iter, ...)

      } else if(algorithm == "BFGS") {

        iter <- update_BFGS(iter, ...)

      } else if(algorithm == "L-BFGS") {

        iter$m <- m
        iter <- update_LBFGS(iter, ...)

      } else if(algorithm == "DFP") {

        iter <- update_DFP(iter, ...)

      } else {

        stop("Available algorithms: gradient, Newton, DFP, BFGS, L-BFGS")

      }

      iter$inprod <- sum(iter$rg * -iter$dir)
      iter$ng <- sqrt(iter$inprod)

      cat("iteration: ", i,
          "f =", iter$f,
          "step size = ", iter$a,
          "ng =", iter$ng, "\r", sep = " ")

    }
  }

  return(iter)

}

