# Updating methods:

update_cg1 <- function(iter, ...) {

  # Fletcher and Reeves (1964)

  iter$rg <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)$rg
  iter$beta <- sum(iter$rg*iter$rg) / sum(iter$old_rg*iter$old_rg)
  iter$dir <- -iter$rg + iter$beta*iter$dir

  return(iter)

}

update_cg2 <- function(iter, ...) {

  # Ribiere and Polyak (1969)

  iter$rg <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)$rg
  iter$y <- iter$rg - iter$old_rg
  iter$beta <- max(sum(iter$y*iter$rg) / sum(iter$old_rg*iter$old_rg), 0)
  iter$dir <- -iter$rg + iter$beta*iter$dir

  return(iter)

}

update_cg3 <- function(iter, ...) {

  # Hestenes and Stiefel (1952)

  iter$rg <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)$rg
  iter$y <- iter$rg - iter$old_rg
  iter$beta <- sum(iter$y*iter$rg) / sum(iter$y*iter$dir)
  iter$dir <- -iter$rg + iter$beta*iter$dir

  return(iter)

}

update_gradient <- function(iter, ...) {

  iter$rg <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)$rg
  iter$dir <- -iter$rg

  return(iter)

}

update_newton <- function(iter, ...) {

  p1 <- nrow(iter$X)
  p2 <- ncol(iter$X)
  gs <- fg(iter$X, f = FALSE, g = TRUE, h = TRUE, ...)
  iter$rg <- gs$rg
  iter$h <- gs$h

  rg <- matrix(iter$rg, ncol = 1)
  dir <- -solve(iter$h, rg)
  iter$dir <- matrix(dir, p1, p2)

  return(iter)

}

update_DFP <- function(iter, ...) {

  p1 <- nrow(iter$X)
  p2 <- ncol(iter$X)
  gs <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)
  y <-  matrix(gs$rg - iter$rg, ncol = 1)
  iter$rg <- gs$rg
  s <- matrix(iter$X - iter$old_X, ncol = 1)
  sy <- sum(s*y)

  if(sy < .Machine$double.eps) { # Discard wrong directions (non-positiveness)
    # Satisfying the curvature condition guarantees positiveness
    iter$dir <- -iter$rg # Gradient descent
    return(iter)
  }

  iter$H <- iter$H + (sy + c(t(y) %*% iter$H %*% y))*(s %*% t(s)) / sy^2 -
    (iter$H %*% y %*% t(s) + s %*% t(y) %*% iter$H) / sy
  # iter$H <- iter$H - (iter$H %*% y %*% t(y) %*% iter$H) / c(t(y) %*% iter$H %*% y) +
    # (s %*% t(s)) / (sy) # Formula 6.15 from Nocedal & Wright
  dir <- iter$H %*% matrix(iter$rg, ncol = 1)
  iter$dir <- matrix(-dir, p1, p2)

  return(iter)

}

update_BFGS <- function(iter, ...) {

  p1 <- nrow(iter$X)
  p2 <- ncol(iter$X)
  I <- diag(p1*p2)
  gs <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)
  y <-  matrix(gs$rg - iter$rg, ncol = 1)
  iter$rg <- gs$rg
  s <- matrix(iter$X - iter$old_X, ncol = 1)
  sy <- sum(s*y)
  p <- 1/sy

  if(sy < .Machine$double.eps) { # Discard wrong directions (non-positiveness)
    # Satisfying the curvature condition guarantees positiveness
    iter$dir <- -iter$rg # Gradient descent
    return(iter)
  }

  syt <- s %*% t(y)
  iter$H <- (I - p*syt) %*% iter$H %*% (I - p*t(syt)) + p*s %*% t(s)
  dir <- iter$H %*% matrix(iter$rg, ncol = 1)
  iter$dir <- matrix(-dir, p1, p2)

  iter$s <- s
  iter$y <- y
  iter$p <- p

  return(iter)

}

update_LBFGS <- function(iter, ...) {

  p1 <- nrow(iter$X)
  p2 <- ncol(iter$X)
  I <- diag(p1*p2)

  # X <- retraction(X, iter$a, iter$dir, ...)
  gs <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)
  # https://en.wikipedia.org/wiki/Limited-memory_BFGS
  k <- length(iter$p) + 1
  m <- max(min(iter$m, k-1), 1)
  q <- matrix(gs$rg, ncol = 1)
  iter$s[[k]] <- matrix(iter$X - iter$old_X, ncol = 1)
  iter$y[[k]] <- matrix(gs$rg - iter$rg, ncol = 1)
  iter$rg <- gs$rg
  sy <- sum(iter$s[[k]]*iter$y[[k]])
  iter$p[[k]] <- 1/sy

  # if(sy < .Machine$double.eps) { # Discard wrong directions (non-positiveness)
  #
  #   stop("Problem with the updated s and y")
  #
  #   iter$s[[k]] <- NULL
  #   iter$y[[k]] <- NULL
  #   iter$p[[k]] <- NULL
  #   k <- k-1 # Use the last k-1 iterations
  #
  #   if(k == 0) { # If there is no previous iteration, then use gradient descent
  #     iter$dir <- -iter$rg
  #     return(iter)
  #   }
  #
  # }

  for(i in k:(k-m+1)) {

    iter$alpha[[i]] <- iter$p[[i]]*sum(iter$s[[i]]*q)
    q <- q - iter$alpha[[i]]*iter$y[[i]]

  }

  gamma <-  sy / sum(iter$y[[k]]*iter$y[[k]])
  H0 <- gamma*I
  z <- H0 %*% q

  for(i in (k-m+1):k) {

    iter$beta[[i]] <- iter$p[[i]] * sum(iter$y[[i]] * z)
    z <- z + iter$s[[i]]*(iter$alpha[[i]] - iter$beta[[i]])

  }

  iter$dir <- matrix(-z, p1, p2)

  return(iter)

}

update_LBFGS2 <- function(iter, ...) {

  k <- length(iter$p) + 1

  if(k < m) {

    iter_BFGS <- update_LBFGS(iter, ...)
    iter$s[[k]] <- iter_BFGS$s
    iter$y[[k]] <- iter_BFGS$y
    iter$p[[k]] <- iter_BFGS$p
    iter$rg <- iter_BFGS$rg
    iter$H <- iter_BFGS$H
    iter$dir <- iter_BFGS$dir

  } else {

  }

  p1 <- nrow(iter$X)
  p2 <- ncol(iter$X)
  I <- diag(p1*p2)

  gs <- fg(iter$X, f = FALSE, g = TRUE, h = FALSE, ...)
  # https://en.wikipedia.org/wiki/Limited-memory_BFGS
  k <- length(iter$p) + 1
  m <- max(min(iter$m, k-1), 1)
  q <- matrix(gs$rg, ncol = 1)
  iter$s[[k]] <- matrix(iter$X - iter$old_X, ncol = 1)
  iter$y[[k]] <- matrix(gs$rg - iter$rg, ncol = 1)
  iter$rg <- gs$rg
  sy <- sum(iter$s[[k]]*iter$y[[k]])
  iter$p[[k]] <- 1/sy

  if(sy < .Machine$double.eps) { # Discard wrong directions (non-positiveness)

    iter$s[[k]] <- NULL
    iter$y[[k]] <- NULL
    iter$p[[k]] <- NULL
    k <- k-1 # Use the last k-1 iterations

    if(k == 0) { # If there is no previous iteration, then use gradient descent
      iter$dir <- -iter$rg
      return(iter)
    }

  }

  for(i in k:(k-m+1)) {

    iter$alpha[[i]] <- iter$p[[i]]*sum(iter$s[[i]]*q)
    q <- q - iter$alpha[[i]]*iter$y[[i]]

  }

  gamma <-  sy / sum(iter$y[[k]]*iter$y[[k]])
  H0 <- gamma*I
  z <- H0 %*% q

  for(i in (k-m+1):k) {

    iter$beta[[i]] <- iter$p[[i]] * sum(iter$y[[i]] * z)
    z <- z + iter$s[[i]]*(iter$alpha[[i]] - iter$beta[[i]])

  }

  iter$dir <- matrix(-z, p1, p2)

  return(iter)

}

# Step size selection by backtracking line search; algorithm 3.1 (page 37):

backtracking <- function(iter, a_multiply = 2, a_min = 0.1, max_iter = 30,
                         c1 = 0.5, c2 = 0.5, algorithm = "BFGS", m = 15, ...) {

  a_multiply = 2
  # iter$a <- min(a_min, iter$a * a_multiply)
  iter$a <- max(a_min, iter$a * a_multiply)

  iter$old_X <- iter$X
  iter$old_rg <- iter$rg
  f0 <- iter$f
  g0 <- sum(iter$rg * iter$dir)

  for ( i in 1:max_iter ) {

    iter$X <- retraction(iter$old_X, iter$a, iter$dir, ...)
    new <- fg(iter$X, f = TRUE, g = FALSE, h = FALSE, ...)
    iter$f <- new$f
    iter$df <- iter$f - f0
    if (iter$df < c1 * iter$a * g0 || iter$a < 1e-09) {# Armijo condition
      # & abs(sum(new$rg * iter$dir)) < c2*abs(g0) # Curvature condition (strong Wolve)
      return(iter)
    }
    iter$a <- iter$a * c2

  }


  # if (i >= max_iter) warning("\n Maximum number of backtracking iterations reached")

  return(iter)

}

cubic <- function(f0, g0, a0, a1, fa0, fa1) {

  a02 <- a0*a0
  a12 <- -a1*a1
  a03 <- -a02*a0
  a13 <- a1*a1*a1

  denominator <- a0*a0*a1*a1*(a1-a0)
  term1 <- fa1 - f0 - g0*a1
  term2 <- fa0 - f0 - g0*a0

  a <- (a02*term1 + a12*term2)/denominator
  b <- (a03*term1 + a13*term2)/denominator

  a2 <- (-b + sqrt(b*b - 3*a*g0)) / (3*a)

  return(a2)

}

strongBacktracking <- function(fn, iter, alpha=1, beta=10e-4, sigma= 0.1, ...) {
  # fn is a function that returns the objective ($f) and Riemannian gradient ($rg)
  # par are the parameters
  # alpha is the initial step size
  # beta and sigma are the Wolfe condition parameters
  par <- iter$X
  dir <- iter$dir
  y0 <- iter$f
  g0 <- sum(iter$rg * dir)
  g <- NA
  y_prev <- NA
  alpha_prev <- 0
  alpha_lo <- NA
  alpha_hi <- NA

  # bracket phase
  while (TRUE) {
    new_X <- retraction(par, alpha, dir, ...)
    x <- fn(new_X, f = TRUE, g = FALSE, h = FALSE, ...)
    yf <- x$f
    if({yf > {y0 + beta*alpha*g0}} | {!is.na(y_prev) & {yf >= y_prev}}) {
      alpha_lo <- alpha_prev
      alpha_hi <- alpha
      break
    }
    x <- fn(new_X, f = FALSE, g = TRUE, h = FALSE, ...)
    g <- sum(x$rg * dir)
    if(abs(g) <= {-sigma * g0}) {
      return(alpha)
    } else if(g >= 0) {
      alpha_lo <- alpha
      alpha_hi <- alpha_prev
      break
    }
    y_prev <- yf
    alpha_prev <- alpha
    alpha <- 2*alpha
  }

  # zoom phase
  # X_lo <- retraction(par, alpha_lo, dir, ...)
  # y_lo <- fn(X_lo, f = TRUE, g = FALSE, h = FALSE, ...)$f
  for(i in 1:5) {
    X_lo <- retraction(par, alpha_lo, dir, ...)
    y_lo <- fn(X_lo, f = TRUE, g = FALSE, h = FALSE, ...)$f
    alpha <- {alpha_lo + alpha_hi}/2
    # alpha <- cubic(y0, g0, alpha_lo, alpha_hi, y_lo, y_hi)
    new_X <- retraction(par, alpha, dir, ...)
    x <- fn(new_X, f = TRUE, g = FALSE, h = FALSE, ...)
    yf <- x$f
    if({yf > {y0 + beta * alpha * g0}} | {yf >= y_lo}) {
      alpha_hi <- alpha
      # y_hi <- yf #
    } else {
      x <- fn(new_X, f = FALSE, g = TRUE, h = FALSE, ...)
      g <- sum(x$rg * dir)
      if(abs(g) <= {-sigma*g0}) {
        return(alpha)
      } else if({g*{alpha_hi - alpha_lo}} >= 0){
        alpha_hi <- alpha_lo
        # y_hi <- y_lo #
      }
      alpha_lo <- alpha
      # y_lo <- yf #
    }
  }

  return(alpha)

}

