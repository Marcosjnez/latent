# Riemannian gradient:

projection_poblq <- function(G, X, ...) {

  # More elegant approach

  Y <- t(X) %*% X
  Q <- t(X) %*% G + t(G) %*% X
  # Q <- zeros(Q, indexes)
  A <- lyap_sym(Y, Q)
  A <- zeros(A, indexes)
  # A <- lyapunov(Y, zeros(Q, indexes))
  diag(A) <- 1
  diag(A) <- diag(Q)/2*diag(A %*% Y)

  N <- X %*% A
  G_proj <- G - N

  return(G_proj)

}

