skew <- function(X) 0.5*(X - t(X)) # returns a skew-symmetric matrix

# Conclusions: solving with lyapunov is a little wrong but works in practice. lyapunov_2 and lyap_sym are ok.

objective <- function(X) {

  Inv_X <- solve(X)
  L <- loadings %*% t(Inv_X)
  return(0.5*sum((Weight * (L - Target))^2))

}

g <- function(X){

  Inv_X <- solve(X)
  L <- loadings %*% t(Inv_X)
  g <- - t(Inv_X) %*% t(Weight^2 * (L - Target)) %*% L

  return(g)

}

dg <- function(Z) {

  Inv_X <- solve(X)
  L <- loadings %*% t(Inv_X)
  Inv_T_dt <- Inv_X %*% Z
  dL <- - L %*% t(Inv_T_dt)
  dg1L <- Weight^2 * dL
  dg <- - g(X) %*% t(Inv_X %*% Z) - t(Z %*% Inv_X) %*% g(X) - t(dg1L %*% Inv_X) %*% L

  return(dg)

}

