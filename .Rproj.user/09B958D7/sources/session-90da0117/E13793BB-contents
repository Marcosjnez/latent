### Riemannian Hessian new projection target criterion

zeros <- function(X, indexes) {

  # Fix to 0 the off-diagonal elements of the oblique blocks:

  n <- length(indexes)
  X0 <- X

  for(i in 1:n) {

    X0[indexes[[i]], indexes[[i]]] <- 0

  }

  diag(X0) <- diag(X)

  return(X0)

}

off <- function(X, indexes) {

  Xoff <- matrix(0, nrow(X), ncol(X))
  n <- length(indexes)

  for(i in 1:n) {

    Xoff[indexes[[i]], indexes[[i]]] <- X[indexes[[i]], indexes[[i]]]

  }

  diag(Xoff) <- 0

  return(Xoff)

}

lyap_sym <- function(Y, Q) {

  # Solve the Lyapunov equation (Q = YA + AY) taking advantage of the
  # symmetry of Y and Q with an eigendecomposition:

  q <- ncol(Y)
  I <- rep(1, q)
  e <- eigen(Y)

  M <- t(e$vectors) %*% Q %*% e$vectors
  W1 <- I %*% t(e$values)
  W <- W1 + t(W1)
  YY <- M / W
  A <- e$vectors %*% YY %*% t(e$vectors)
  
  # lw <- eigen(W)$values; vw <- eigen(W)$vectors
  # vw %*% diag(lw) %*% t(vw)

  return(A)

}

lyapunov <- function(Y, Q) { # Deprecated

  # Solve the Lyapunov equation (Q = YA + AY) for A:

  q <- nrow(Y)
  I <- diag(1, q)
  Y1 <- kronecker(I, Y)
  Y2 <- kronecker(Y, I)
  X <- Y1 + Y2
  # A and Q are symmetric and some in Q are fixed to 0, so you may solve fewer equations:
  remove_index <- Q != 0 & lower.tri(Q, diag = TRUE)
  Q <- Q[remove_index]
  X <- X[, c(remove_index)][c(remove_index), ]
  Lambda <- solve(X, Q)
  A <- matrix(0, q, q)
  A[remove_index] <- Lambda
  A[upper.tri(A)] <- t(A)[upper.tri(A)]

  return(A)

}

