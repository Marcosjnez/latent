  s <- nrow(Y)
  J <- ncol(Y)
  Iv <- rep(1, s)

  u <- x[1:nc]
  z <- x[-(1:nc)]

  pX <- log(u)
  pYX <- matrix(z, nrow = J, ncol = nc)

  pyx <- matrix(NA, nrow = s, ncol = nc)
  pitems <- array(NA, dim = c(s, J, nc))
  for(i in 1:nc) {
