f2 <- function(x, n, y, nc) {

  u <- x[1:nc]
  z <- x[-(1:nc)]
  z1 <- z[1:3]
  z2 <- z[-(1:3)]

  lik1 <- dbinom(y, 1, z1)
  lik2 <- dbinom(y, 1, z2)
  l <- n*log(prod(lik1)*u[1] +
                prod(lik2)*u[2])
  return(l)

}

g2 <- function(x, n, y, nc) {

  u <- x[1:nc]
  z <- x[-(1:nc)]
  z1 <- z[1:3]
  z2 <- z[-(1:3)]

  lik1 <- dbinom(y, 1, z1)
  lik2 <- dbinom(y, 1, z2)
  mid <- prod(lik1)*u[1] + prod(lik2)*u[2]
  glu <- n/mid*c(prod(lik1), prod(lik2))

  # p1 <- (1-z1)^y*(y-z1)*z1^(y-1)
