#### Derivatives of softmax (with covariates) ####

f6 <- function(x, Z) {

  y <- Z %*% x
  p <- exp(y)/sum(exp(y))
  return(p)

}

g6 <- function(x, z) {

  y <- Z %*% x
  soft <- exp(y)/sum(exp(y))
  jacobian <- -soft %*% t(soft)
  diag(jacobian) <- soft*(1-soft)
  g <- jacobian %*% Z

  return(g)

}

