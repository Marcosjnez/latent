EM <- function(x, n, Y, nc, maxit = 100, eps = 1e-05) {

  pX <- exp(x[1:nc]) / sum(exp(x[1:nc]))
  pYX <- matrix(plogis(x[-(1:nc)]), nrow = J, ncol = nc)
  pyx <- matrix(NA, nrow = s, ncol = nc)
  Iv <- rep(1, s)
  loglik <- c(1000)

  for(k in 2:maxit) {

    # E-step

    for(i in 1:nc) {
      # pyXi <- matrix(rep(pYX[, i], each = s), nrow = s, ncol = J)
      # pyx[, i] <- apply(dbinom(Y, 1, pyXi), MARGIN = 1, prod) # P(data | X = c)
      # pyx[, i] <- rowSums(dbinom(Y, 1, pyXi, log = TRUE)) # log(P(data | X = c))
      # pyx[, i] <- rowSums(log(((1-Y)*(1-pyXi)/pyXi + Y)*pyXi))
      pyXi <- Iv %*% t(pYX[, i])
      pyx[, i] <- rowSums(log(2*pyXi*Y - pyXi - Y + 1))
    }

    pYXX <- exp(t(t(pyx) + log(pX))) # P(data |X = c) P(X = c)
    pD <- rowSums(pYXX) # P(data)
    # pD <- pyx %*% pX # P(data)
    posterior <- pYXX / c(pD) # P(X = c | data) = P(data | X = c) P(X = c) / P(data)

    # M-step
    freqs <- n*posterior # Posterior frequencies of each response pattern
    post_total <- colSums(freqs)
    post_freqs <- t(Y) %*% freqs

    pX <- post_total / sum(post_total)
    pYX <- t(t(post_freqs) / post_total)

    parameters <- c(pX, pYX)
    loglik <- c(loglik, sum(n*(log(pD))))
    fnorm <- sum((loglik[k]-loglik[k-1])^2)
    cat("Iteration", k, ": loglik =", round(loglik[k], 6), "\n")
    x <- parameters
    if(fnorm < eps) break

  }

  return(list(x = x, fnorm = fnorm, loglik = loglik[k], posterior = posterior,
              pX = pX, pYX = pYX, iterations = i))

}

EM(x, n, Y, nc, maxit = 100, eps = 1e-05)

