#### Derivative wrt all response patterns (softmax link) ####

softmax <- function(x) {
  p <- exp(x)/sum(exp(x))
  return(p)
}
f <- function(x, n, Y, nc) {

  # data = all response patterns
  # X = class
  # pyx = P(data | X = c)
  # pX = P(X = c)

  u <- x[1:nc]
  z <- x[-(1:nc)] # P(data | X = c)

  S <- nrow(Y) # Number of patterns
  # K is the vector with the number of categories per item
  J <- ncol(Y) # Number of items

  indices <- target <- vector("list", length = J)
  K <- vector(length = J)
  end <- nc
  for(j in 1:J) {
    K[j] <- max(Y[, j])
    start <- end + 1
    end <- start + K[j]*nc - 1
    indices[[j]] <- matrix(start:end, nrow = K[j], ncol = nc)
    target[[j]] <- indices[[j]] - nc
  }

  softu <- softmax(u) # P(X = c)
  # For each item, create a k x nc matrix:
  softZ <- lsoftZ <- vector("list", length = J)

  lsoftu <- log(softu) # log(P(X = c))

  lik <- array(NA, dim = c(J, nc, S))
  loglik <- vector(length = S) # loglik for each response pattern

    for(j in 1:J) {
      softZ[[j]] <- lsoftZ[[j]] <- matrix(NA, nrow = K[j], ncol = nc)
      for(i in 1:nc) {
        softZ[[j]][, i] <- softmax(x[indices[[j]][, i]]) # P(data | X = c)
        lsoftZ[[j]][, i] <- log(softZ[[j]][, i]) # log(P(data | X = c))
        for(s in 1:S) {
          lik[j, i, s] <- lsoftZ[[j]][Y[s, j], i]
        }
      }
    }

  # For each response pattern s:
  for(s in 1:S) {
    loglik[s] <- n[s] * log(sum(exp(colSums(lik[, , s]) + lsoftu))) # P(data)
  }

  f <- -sum(loglik)

  return(f)

}

g <- function(x, n, Y, nc) {

  # data = all response patterns
  # X = class
  # pyx = P(data | X = c)
  # pX = P(X = c)
  u <- x[1:nc]
  z <- x[-(1:nc)] # P(data | X = c)

  S <- nrow(Y) # Number of patterns
  # K is the vector with the number of categories per item
  J <- ncol(Y) # Number of items

  indices <- target <- vector("list", length = J)
  K <- vector(length = J)
  end <- nc
  for(j in 1:J) {
    K[j] <- max(Y[, j])
    start <- end + 1
    end <- start + K[j]*nc - 1
    indices[[j]] <- matrix(start:end, nrow = K[j], ncol = nc)
    target[[j]] <- indices[[j]] - nc
  }

  softu <- softmax(u) # P(X = c)
  # For each item, create a k x nc matrix:
  softZ <- lsoftZ <- glZ <- vector("list", length = J)

  lsoftu <- log(softu) # log(P(X = c))

  lik <- array(NA, dim = c(J, nc, S))

  for(j in 1:J) {
    softZ[[j]] <- lsoftZ[[j]] <- matrix(NA, nrow = K[j], ncol = nc)
    glZ[[j]] <- matrix(0, nrow = K[j], ncol = nc)
    for(i in 1:nc) {
      softZ[[j]][, i] <- softmax(x[indices[[j]][, i]]) # P(data | X = c)
      lsoftZ[[j]][, i] <- log(softZ[[j]][, i]) # log(P(data | X = c))
      for(s in 1:S) {
        lik[j, i, s] <- lsoftZ[[j]][Y[s, j], i]
      }
    }
  }

  glu <- rep(0, length(u))

  # For each response pattern s:
  for(s in 1:S) {
    mid <- sum(exp(colSums(lik[, , s]) + lsoftu))
    glu <- -exp(log(n[s]) - log(mid) + colSums(lik[, , s])) + glu
  }

  for(s in 1:S) {
    mid <- sum(exp(colSums(lik[, , s]) + lsoftu))
    term <- log(n[s]) - log(mid) + lsoftu + colSums(lik[, , s])
    for(j in 1:J) {
      for(i in 1:nc) {
        add <- glZ[[j]][Y[s, j], i]
        glZ[[j]][Y[s, j], i] <- -exp(term[i] - lik[j, i, s]) + add
      }
    }
  }

  glz <- c()

  for(j in 1:J) {
    for(i in 1:nc) {
      vector <- softZ[[j]][, i]
      jacobian <- -vector %*% t(vector)
      diag(jacobian) <- vector*(1-vector)
      glZ[[j]][, i] <- glZ[[j]][, i] %*% jacobian
      glz <- c(glz, glZ[[j]][, i])
    }
  }

  jacobian <- -softu %*% t(softu)
  diag(jacobian) <- softu*(1-softu)
  glu <- glu %*% jacobian

  g <- unname(c(glu, glz))

  return(g)

}

