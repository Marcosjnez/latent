# E step: compute P(X = c | data) (Posterior)
# M step: Use P(X = c | data) as weights to estimate P(X = c) and P(data | X = c)

#### Derivative wrt a single response pattern and two classes ####

f2 <- function(x, n, y, nc, K) {

  # K is the Number of categories
  J <- length(y) # Number of items

  u <- x[1:nc] # P(X = c)
  z <- x[-(1:nc)] # P(data | X = c)

  pX <- log(u) # log(P(X = c))
  lZ <- array(log(z), dim = c(K, J, nc)) # log(P(data | X = c))

  lik <- matrix(NA, nrow = J, ncol = nc)
  for(i in 1:nc) {
    for(j in 1:J) {
      lik[j, i] <- lZ[y[j]+1, j, i]
    }
  }

  pYXX <- exp(colSums(lik) + pX)
  pD <- sum(pYXX) # P(data)
  loglik <- n * log(pD)
  f <- -sum(loglik)

  return(f)

}

g2 <- function(x, n, y, nc, K) {

  # K is the Number of categories
  J <- length(y) # Number of items

  u <- x[1:nc] # P(X = c)
  z <- x[-(1:nc)] # P(data | X = c)

  pX <- log(u) # log(P(X = c))
  lZ <- array(log(z), dim = c(K, J, nc)) # log(P(data | X = c))

  lik <- matrix(NA, nrow = J, ncol = nc)
  for(i in 1:nc) {
    for(j in 1:J) {
      lik[j, i] <- lZ[y[j]+1, j, i]
    }
  }

  mid <- sum(exp(colSums(lik) + pX))
  glu <- -exp(log(n) - log(mid) + colSums(lik))

  term <- log(n) - log(mid) + pX + colSums(lik)
  Z <- array(0, dim = c(K, J, nc)) # P(data | X = c)
  for(i in 1:nc) {
    for(j in 1:J) {
      Z[(y+1)[j], j, i] <- -exp(term[i] - lik[j, i])
    }
  }

  X <- cbind(n*exp(pX)*exp(colSums(lik))/exp(lik[1, ]) / mid,
             n*exp(pX)*exp(colSums(lik))/exp(lik[2, ]) / mid,
             n*exp(pX)*exp(colSums(lik))/exp(lik[3, ]) / mid)
  X
  for(j in 1:J) {
    n*exp(pX)*exp(colSums(lik)) / mid / lik[j, ]
  }

  return(c(glu, c(Z)))

}

h2 <- function(x, n, y, nc, K) {

  # K is the Number of categories
  J <- length(y) # Number of items

  u <- x[1:nc] # P(X = c)
  z <- x[-(1:nc)] # P(data | X = c)

  pX <- log(u) # log(P(X = c))
  lZ <- array(log(z), dim = c(K, J, nc)) # log(P(data | X = c))

  lik <- matrix(NA, nrow = J, ncol = nc)
  for(i in 1:nc) {
    for(j in 1:J) {
      lik[j, i] <- lZ[y[j]+1, j, i]
    }
  }

  mids <- exp(colSums(lik) + pX)
  mid <- sum(mids)
  # u <- n*exp(colSums(lik))
  # v <- mid
  # glu2 <- u*exp(colSums(lik)) / v^2
  cc <- exp(colSums(lik))
  glu2 <- n*cc %*% t(cc) / mid^2

  PX <- exp(pX) %*% t(exp(pX))
  PC <- cc %*% t(cc)
  numer <- n*PX * PC
  glz2 <- numer/mid^2

  term <- log(n) - log(mid) + pX + colSums(lik)
  Z <- array(0, dim = c(K, J, nc)) # P(data | X = c)
  for(i in 1:nc) {
    for(j in 1:J) {
      Z[(y+1)[j], j, i] <- -exp(term[i] - lik[j, i])
    }
  }

  return(glu2)

}

