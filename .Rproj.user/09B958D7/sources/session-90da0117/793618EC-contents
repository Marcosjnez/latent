#### Derivative wrt all response patterns ####

f1 <- function(x, n, Y, nc, K) {

  # data = all response patterns
  # X = class
  # pyx = P(data | X = c)
  # pX = P(X = c)
  S <- nrow(Y) # Number of patterns
  # K is the vector with the number of categories per item
  J <- ncol(Y) # Number of items

  u <- x[1:nc] # P(X = c)
  z <- x[-(1:nc)] # P(data | X = c)

  pX <- log(u) # log(P(X = c))
  lZ <- array(log(z), dim = c(max(K), J, nc)) # log(P(data | X = c))
  lZ[is.infinite(lZ)] <- 0

  lik <- array(NA, dim = c(J, nc, S))
  loglik <- vector(length = S)

  for(s in 1:S) {
    for(i in 1:nc) {
      for(j in 1:J) {
        lik[j, i, s] <- lZ[Y[s, j], j, i]
      }
    }
    loglik[s] <- n[s] * log(sum(exp(colSums(lik[, , s]) + pX))) # P(data)
  }

  f <- -sum(loglik)

  return(f)

}

g1 <- function(x, n, Y, nc, K) {

  S <- nrow(Y)
  # K is the vector with the number of categories per item
  J <- ncol(Y) # Number of items

  u <- x[1:nc] # P(X = c)
  z <- x[-(1:nc)] # P(data | X = c)

  pX <- log(u) # log(P(X = c))
  lZ <- array(log(z), dim = c(max(K), J, nc)) # log(P(data | X = c))

  Z <- array(0, dim = c(max(K), J, nc))
  glu <- rep(0, length(u))

  lik <- array(NA, dim = c(J, nc, S))

  for(s in 1:S) {
    for(i in 1:nc) {
      for(j in 1:J) {
        lik[j, i, s] <- lZ[Y[s, j], j, i]
      }
    }
    mid <- sum(exp(colSums(lik[, , s]) + pX))
    glu <- -exp(log(n[s]) - log(mid) + colSums(lik[, , s])) + glu

  }

  for(s in 1:S) {
    mid <- sum(exp(colSums(lik[, , s]) + pX))
    term <- log(n[s]) - log(mid) + pX + colSums(lik[, , s])
    for(i in 1:nc) {
      for(j in 1:J) {
        add <- Z[Y[s, j], j, i]
        Z[Y[s, j], j, i] <- -exp(term[i] - lik[j, i, s]) + add
      }
    }
  }

  g <- c(glu, c(Z))

  return(g)

}

