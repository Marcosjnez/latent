# Example

```{r, eval=FALSE, echo=FALSE}
# A = Matrix of predictors
# x = parameter vector
# y = response vector
# f = value of the objective function at x
# g = gradient of the objective function at x
# t step size

# Define the objective function:
objective <- function(A, x, y) {
  
  f <- sum((y - A %*% x)^2)
  
  return( f )
  
}
# Define the gradient:
gradient <- function(A, x, y) {
  
  g <- -2 * t(A) %*% (y - A %*% x)
  g <- matrix(g, ncol = 1)
  
  return( g )
  
}
# Define the projection
projection <- function(g) {
  
  V <- rbind(c(-1, -1), # Basis for the tangent space
             c( 1,  0),
             c( 0,  1))
  # Project the gradient onto the tangent space:
  rg <- V %*% solve(t(V) %*% V) %*% t(V) %*% g # Riemannian gradient
  
  return(rg)
  
}
# Define the retraction
retraction <- function(x, t, rg) {
  
  x <- x + t*rg # Update
  # x <- x / sum(x) # Sum to 0 constraint
  x <- x - mean(x)
  
  return(x)
  
}

# Simulate data:
set.seed(1)
n <- 1000                       # Observations
p <- 3                          # Number of predictors
A <- replicate(p, rnorm(n))     # Matrix of predictors
x <- matrix(runif(p, -1, 1), ncol = 1) # Coefficients
y <- A %*% x + rnorm(n, 0, 0.1) # Response vector

# Gradient descent algorithm:

maxit <- 1e4 # Number of iterations
eps <- 1e-4  # Tolerance for the norm of the gradient
al <- 1      # Initial step size
xhat <- matrix(runif(p), ncol = 1) # Starting parameter values
xhat <- retraction(xhat, 0, 0)     # Project the initial values onto the manifold

f <- objective(A, x, y)
g <- gradient(A, x, y)
rg <- projection(g)

for (iter in 0:maxit) {
  s <- sqrt(sum(rg^2))
  if (s < eps)
    break
  al <- 2 * al
  for (i in 0:10) {
    x_temp <- retraction(xhat, al, -rg)
    improvement <- f - objective(A, x_temp, y)
    if (improvement > 0.5 * s^2 * al) 
      break
    al <- al/2
  }
  xhat <- x_temp
  f <- objective(A, xhat, y)
  g <- gradient(A, xhat, y)
  rg <- projection(g)
  cat("\r", "Iteration = ", iter)
}

# Check the constraint sum(xhat) == 0
sum(xhat)

# You may consider other manifolds by changing the projection and retraction:

# Unit length manifold:

projection <- function(g, x) {
  
  I <- diag(length(x))
  rg <- (I - x %*% t(x)) %*% g
  
  return( rg )
  
}
retraction <- function(x, t, rg) {
  
  x <- x + t*rg
  x <- x / sqrt(sum(x^2))
  
  return( x )
  
}

# Gradient descent algorithm:

maxit <- 1e4 # Number of iterations
eps <- 1e-4  # Tolerance for the norm of the gradient
al <- 1      # Initial step size
xhat <- matrix(runif(p), ncol = 1) # Starting parameter values
xhat <- retraction(xhat, 0, 0)     # Project the initial values onto the manifold

f <- objective(A, x, y)
g <- gradient(A, x, y)
rg <- projection(g, x)

for (iter in 0:maxit) {
  s <- sqrt(sum(rg^2))
  if (s < eps)
    break
  al <- 2 * al
  for (i in 0:10) {
    x_temp <- retraction(xhat, al, -rg)
    improvement <- f - objective(A, x_temp, y)
    if (improvement > 0.5 * s^2 * al) 
      break
    al <- al/2
  }
  xhat <- x_temp
  f <- objective(A, xhat, y)
  g <- gradient(A, xhat, y)
  rg <- projection(g, xhat)
  cat("\r", "Iteration = ", iter)
}

# Check the constraint crossprod(xhat) == 1
t(xhat) %*% xhat
```

