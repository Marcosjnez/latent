zoom <- function(iter, alo, ahi, c1, c2, zoom_max_iter = 5, interpolation = "quadratic", ...) {

  # cat("\n Zoom algorithm \n")

  f0 <- iter$f
  g0 <- iter$inprod

  i <- 1

  while(i < zoom_max_iter) {

    X <- retraction(iter$X, alo, iter$dir, ...)
    f_g <- fg(X, f = TRUE, g = TRUE, ...)
    falo <- f_g$f
    galo <- sum( f_g$rg * iter$dir )

    aj <- interpolate(iter, alo, ahi, interpolation, ...)
    X <- retraction(iter$X, aj, iter$dir, ...)
    f_g <- fg(X, f = TRUE, g = TRUE, ...)
    faj <- f_g$f
    gaj <- sum( f_g$rg * iter$dir )

    condition1 <- faj > f0 + c1*aj*g0 || faj >= falo
    condition2 <- abs(gaj) <= abs(c2*g0)
    condition3 <- gaj * (ahi - alo) >= 0 # gaj >= 0

    if(condition1) { # if armijo condition is violated, look up a smaller step

      # cat(crayon::blue("\n armijo condition violated \n "))

      ahi <- aj

    } else {

      if(condition2) { # curvature condition

        # cat(crayon::green("\n armijo and curvature conditions satisfied \n "))

        break

      }

      if(condition3) {

        # cat(crayon::magenta("\n the gradient is positive \n "))

        ahi <- alo

      }

      alo <- aj

    }

    i <- i+1

  }

  if(i == zoom_max_iter) {

    warning("Maximum zoom iteration reached")

  }

  # cat("\n zoom iterations = ", i, "\n")

  return(aj)

}

lnsrch <- function(iter, c1 = 10e-4, c2 = 0.9, ln_max_iter = 10,
                   zoom_max_iter = 5, interpolation = "quadratic", ...) {

  # cat("\n Line search algorithm \n")

  a_max <- 10

  a <- fa <- ga <- vector(length = ln_max_iter + 1)
  a[1] <- 0
  f0 <- fa[1] <- iter$f
  g0 <- ga[1] <- iter$inprod

  # a[2] <- iter$a
  a[2] <- min(1, 1.01*iter$a)
  X <- retraction(iter$X, a[2], iter$dir, ...)
  f_g <- fg(X, f = TRUE, g = TRUE, ...)
  fa[2] <- f_g$f
  ga[2] <- sum( f_g$rg * iter$dir ) # Riemannian gradient * p

  i <- 2

  while(i < ln_max_iter) {

    condition_1 <- (fa[i] > f0 + c1*a[i]*g0) || ((i > 2) && fa[i] >= fa[i-1]) # sufficient decrease condition (armijo) violated
    condition_2 <- abs(ga[i]) <= abs(c2*g0) # curvature condition
    condition_3 <- ga[i] >= 0 #&& (i > 2)

    if(condition_1) { # (a[i-1], a[i]) contains acceptable step sizes

      # cat(crayon::blue("\n armijo condition violated 1 \n "))

      a[i+1] <- zoom(iter, a[i-1], a[i], c1, c2, zoom_max_iter, interpolation, ...)
      step <- a[i+1]
      X <- retraction(iter$X, a[i+1], iter$dir, ...)
      f_g <- fg(X, f = TRUE, g = TRUE, ...)
      fa[i+1] <- f_g$f
      ga[i+1] <- sum( f_g$rg * iter$dir ) # Riemannian gradient * p

      break

    }

    if(condition_2) {

      # cat(crayon::green("\n armijo and curvature conditions satisfied \n"))

      a[i+1] <- a[i]
      step <- a[i+1]
      X <- retraction(iter$X, a[i+1], iter$dir, ...)
      f_g <- fg(X, f = TRUE, g = TRUE, ...)
      fa[i+1] <- f_g$f
      ga[i+1] <- sum( f_g$rg * iter$dir ) # Riemannian gradient * p

      break

    }

    if(condition_3) { # (a[i], a[i-1]) contains acceptable step sizes

      # cat(crayon::bgMagenta("\n the gradient is positive \n"))

      a[i+1] <- zoom(iter, a[i-1], a[i], c1, c2, zoom_max_iter, interpolation, ...)
      step <- a[i+1]
      X <- retraction(iter$X, a[i+1], iter$dir, ...)
      f_g <- fg(X, f = TRUE, g = TRUE, ...)
      fa[i+1] <- f_g$f
      ga[i+1] <- sum( f_g$rg * iter$dir ) # Riemannian gradient * p

      break

    }

    # Increase step size:

    # cat(crayon::red("\n armijo condition satisfied but curvature condition violated \n"))

    # a[i+1] <- (a_max + a[i])/2
    a[i+1] <- interpolate(iter, a[i], a_max, interpolation, ...)
    step <- a[i+1]
    X <- retraction(iter$X, a[i+1], iter$dir, ...)
    f_g <- fg(X, f = TRUE, g = TRUE, ...)
    fa[i+1] <- f_g$f
    ga[i+1] <- sum( f_g$rg * iter$dir ) # Riemannian gradient * p

    i <- i+1

  }

  # cat("\n line search iterations = ", i-1, "\n")

  if(i == ln_max_iter) {

    warning("Maximum line search iteration reached")

  }


  iter$X <- X
  iter$f <- f_g$f
  iter$g <- f_g$g
  iter$rg <- f_g$rg
  iter$a <- step
  iter$dir <- -iter$rg
  iter$inprod <- sum(iter$dir * iter$rg)
  iter$ng <- norm(iter$rg, type = 'F')
  iter$fa
  iter$ga

  return(iter)

}

armijo <- function(iter, ss.fac = 2, ss.min = 0.1, max_iter = 30, c1 = 10e-4, c2 = 0.9,...) {

  iter$a <- max(ss.min, iter$a * ss.fac)

  X <- iter$X
  f0 <- iter$f

  for ( i in 1:max_iter ) {

    iter$X <- retraction(X, iter$a, iter$dir, ...)
    iter$f <- fg(iter$X, f = TRUE, g = FALSE, ...)$f
    df <- f0 - iter$f
    if (df >= -c1 * iter$a * iter$inprod) # armijo condition
      break
    iter$a <- iter$a * c2

  }

  if (i >= max_iter) warning("Maximum number of backtracking iterations reached")

  gs <- fg(iter$X, f = FALSE, g = TRUE, ...)
  iter$g <- gs$g
  iter$rg <- gs$rg
  iter$dir <- -iter$rg
  iter$inprod <- sum(iter$dir * iter$rg)
  iter$ng <- norm(iter$rg, type = 'F')

  return(iter)

}

Roptim <- function(X, projection, retraction, search = "strongwolve", maxit = 1e3,
                   c1 = 10e-04, c2 = 0.9, max_inner_iter = 10, zoom_max_iter = 5,
                   ss.fac = 2, ss.min = 0.1, interpolation = "quadratic", ...) {

  options(warn = 1)

  f_g <- fg(X, f = TRUE, g = TRUE, ...)
  f <- f_g$f
  g <- f_g$g
  rg <- projection(g, X, ...)

  iter <- list()
  iter$X <- X
  iter$f <- f
  iter$g <- g
  iter$rg <- rg
  iter$dir <- -rg
  iter$inprod <- sum(iter$dir * iter$rg)
  iter$ng <- norm(iter$rg, type = 'F')
  iter$a <- 1

  if(search == "armijo") {

    for (i in 1:maxit) {

      if (iter$ng < eps) break

      iter <- armijo(iter, ss.fac, ss.min, max_inner_iter, c1, c2, ...)

      cat("iteration: ", i,
          "f =", iter$f,
          "step size = ", iter$a,
          "ng =", iter$ng, "\r", sep = " ")

    }

  } else if(search == "strongwolfe") {

    for (i in 1:maxit) {

      if (iter$ng < eps) break

      iter <- lnsrch(iter, c1, c2, max_inner_iter, zoom_max_iter, interpolation, ...)

      cat("iteration: ", i,
          "f =", iter$f,
          "step size = ", iter$a,
          "ng =", iter$ng, "\r", sep = " ")


    }
  }

  iter$iterations <- i

  return(iter)

}

