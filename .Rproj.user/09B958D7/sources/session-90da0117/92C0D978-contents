  L2N <- L2 %*% N
  IL2N <- diag(1, nrow(A)) %*% L2N

  if(f) {

    f1 <- sum(diag(t(L2) %*% IL2N))/4

  } else {

    f1 <- NULL

  }

  if(g) {

    g1 <- -t(t(L) %*% (L * IL2N) %*% Inv_X)
    rg <- projection(g1, X, ...)

  } else {

    g1 <- rg <- NULL

  }

  return(list(f = f1, g = g1, rg = rg))

