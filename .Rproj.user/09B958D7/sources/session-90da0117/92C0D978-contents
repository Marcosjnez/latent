# oblimin + target en correlaciones:
fg <- function(X, f = TRUE, g = FALSE, ...) {

  Inv_T <- solve(X)
  L <- A %*% t(Inv_T)
  n <- nrow(L)
  p <- ncol(L)
  I <- diag(1, n, n)
  C <- matrix(1/n, n, n)
  gamma <- 0
  gammaC <- gamma*C
  N <- matrix(1, p, p)
  diag(N) <- 0
  L0 <- cbind(L[, -indexes[[2]]], 0)
  L2 <- L0^2
  IgCL2N <- ((I - gammaC) %*% L2 %*% N)
  Phi <- t(X) %*% X
  Target <- matrix(1, p, p)
  diag(Target) <- 0
  Target[p, ] <- Target[, p] <- 0
  PT <- (Phi - Target)

  if(f) {

    f1 <- sum(diag(crossprod(L2, IgCL2N)))/4
    f2 <- sum(diag(t(PT) %*% PT))
    f1 <- f1 + f2

  } else {

    f1 <- NULL

  }

  if(g) {

    gradient_A <- L0 * IgCL2N
    gradient1 = -t(t(L) %*% gradient_A %*% Inv_T)
    gradient2 <- 4*X %*% (Phi - Target)

    g1 <- gradient1 + gradient2

    rg <- projection(g1, X, A, indexes)

  } else {

    g1 <- rg <- NULL

  }

  return(list(f = f1, g = g1, rg = rg))

}

# geomin + target en correlaciones:
fg <- function(X, f = TRUE, g = FALSE, ...) {

  Inv_T <- solve(X)
  L <- A %*% t(Inv_T)
  k <- ncol(L)
  p <- nrow(L)
  L0 <- cbind(L[, -indexes[[2]]], 0)
  L2 <- L0^2 + delta
  pro <- exp(rowSums(log(L2))/k)

  Phi <- t(X) %*% X
  Target <- matrix(1, k, k)
  diag(Target) <- 0
  Target[k, ] <- Target[, k] <- 0
  PT <- (Phi - Target)

  if(f) {

    f1 <- sum(pro)
    f2 <- sum(diag(t(PT) %*% PT))
    f1 <- f1 #+ f2

  } else {

    f1 <- NULL

  }

  if(g) {

    gradient_A <- (2/k) * (cbind(L[, -indexes[[2]]], 0)/L2) * matrix(rep(pro, k), p)
    gradient1 = -t(t(L) %*% gradient_A %*% Inv_T)
    gradient2 <- 4*X %*% (Phi - Target)

    g1 <- gradient1 #+ gradient2

    rg <- projection(g1, X, A, indexes)

  } else {

    g1 <- rg <- NULL

  }

  return(list(f = f1, g = g1, rg = rg))

}

# oblimin + oblimin:
fg <- function(X, f = TRUE, g = FALSE, ...) {

  n <- ncol(A)
  Inv_X <- solve(X)
  L <- A %*% t(Inv_X)
  L0_1 <- matrix(0, nrow(A), ncol(A))
  L0_1[, indexes[[1]]] <- L[, indexes[[1]]]
  L2_1 <- L0_1^2
  N <- matrix(1, n, n); diag(N) <- 0
  L2N <- L2_1 %*% N
  IL2N_1 <- diag(1, nrow(A)) %*% L2N

  L0_2 <- matrix(0, nrow(A), ncol(A))
  L0_2[, indexes[[2]]] <- L[, indexes[[2]]]
  L2_2 <- L0_2^2
  N <- matrix(1, n, n); diag(N) <- 0
  L2N <- L2_2 %*% N
  IL2N_2 <- diag(1, nrow(A)) %*% L2N

  if(f) {

    f1 <- sum(diag(t(L2_1) %*% IL2N_1))/4 +
      sum(diag(t(L2_2) %*% IL2N_2))/4

  } else {

    f1 <- NULL

  }

  if(g) {

    g1 <- -t(t(L) %*% (L0_1 * IL2N_1) %*% Inv_X) -
      t(t(L) %*% (L0_2 * IL2N_2) %*% Inv_X)
    rg <- projection(g1, X, ...)

  } else {

    g1 <- rg <- NULL

  }

  return(list(f = f1, g = g1, rg = rg))

}

