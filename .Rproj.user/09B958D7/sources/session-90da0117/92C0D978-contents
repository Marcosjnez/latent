symm <- function(X) (X + t(X)) / 2

skew <- function(X) (X - t(X)) / 2

projection_oblq <- function(G, X) {

  G_proj <- G - X %*% diag(diag(t(X) %*% G))

  return(G_proj)

}

retraction_oblq <- function(X) {

  X_oblq <- X %*% (diag(1/sqrt(diag(t(X) %*% X))))

  return(X_oblq)

}

projection_orth <- function(G, X) {

  Lambda <- symm(X %*% t(G))
  G_proj <- (G - Lambda %*% X)

  return(G_proj)

}

retraction_orth <- function(X) {

  X_orth <- qr.Q(qr(X))

  return(X_orth)

}

retraction_poblq <- function(X, ss, V, A, indexes) {

  X <- X + ss*V
  X <- retraction_oblq(X)
  QR <- qr(X)
  Q <- qr.Q(QR)

  I <- length(indexes)-1

  if(I == 0) {

    X[, -indexes[[1]]] <- Q[, -indexes[[1]]]

  } else {

    for(i in 1:I) {

      cum_indexes <- unlist(indexes[1:i])
      orthogonals <- Q[, cum_indexes, drop = FALSE]
      n <- ncol(orthogonals)

      for(j in indexes[[i+1]]) {

        A <- cbind(orthogonals, X[, j])
        X[, j] <- gram(A)[, n+1]

      }

    }

    X[, -unlist(indexes)] <- Q[, -unlist(indexes)]

  }

  return(X)

}

gram <- function(V) {

  n <- nrow(V)
  k <- ncol(V)
  U <- matrix(0, n, k)
  U[, 1] <- V[, 1] / sqrt(sum(V[, 1]^2))

  for(i in 2:k) {

    U[, i] <- V[, i]

    for(j in 1:(i-1)) {

      U[, i] <- U[, i] - sum(U[, j]*U[, i]) / sum(U[, j]^2) * U[, j]

    }

    U[, i] <- U[, i] / sqrt(sum(U[, i]^2))

  }

  return(U)

}
zeros <- function(X, indexes) {

  n <- length(indexes)
  X0 <- X

  for(i in 1:n) {

    X0[indexes[[i]], indexes[[i]]] <- 0

  }

  diag(X0) <- diag(X)

  return(X0)

}
off <- function(X, indexes) {

  Xoff <- matrix(0, nrow(X), ncol(X))
  n <- length(indexes)

  for(i in 1:n) {

    Xoff[indexes[[i]], indexes[[i]]] <- X[indexes[[i]], indexes[[i]]]

  }

  diag(Xoff) <- 0

  return(Xoff)

}
lyapunov <- function(Y, Q) {

  q <- nrow(Y)
  I <- diag(1, q)
  Y1 <- kronecker(I, Y)
  Y2 <- kronecker(Y, I)
  X <- Y1 + Y2
  remove_index <- Q != 0 & lower.tri(Q, diag = TRUE)
  Q <- Q[remove_index]
  X <- X[, c(remove_index)][c(remove_index), ]
  Lambda <- solve(X, Q)
  A <- matrix(0, q, q)
  A[remove_index] <- Lambda
  A[upper.tri(A)] <- t(A)[upper.tri(A)]

  return(A)

}
projection_poblq <- function(G, X, ...) {

  X0 <- zeros(t(X) %*% G + t(G) %*% X, indexes)
  Y <- t(X) %*% X
  A <- lyapunov(Y, X0)
  # Y %*% A + A %*% Y
  N <- X %*% A
  G_proj <- G - N

  return(G_proj)

}
