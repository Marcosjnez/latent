interpolate <- function(iter, alo, ahi, interpolation = "quadratic", ...) {

  Xhi <- retraction(iter$X, ahi, iter$dir, ...)
  fahi <- fg(Xhi, f = TRUE, g = TRUE, ...)
  gahi <- sum( fahi$rg * iter$dir )

  Xlo <- retraction(iter$X, alo, iter$dir, ...)
  falo <- fg(Xlo, f = TRUE, g = TRUE, ...)
  galo <- sum( falo$rg * iter$dir )

  a1 <- -0.5*(galo*ahi^2) / (fahi$f - falo$f - galo*ahi)
  if(a1 > ahi || a1 < alo) a1 <- (ahi + alo)/2

  if(interpolation == "cubic") {

    Xa1 <- retraction(iter$X, a1, iter$dir, ...)
    fa1 <- fg(Xa1, f = TRUE, g = FALSE, ...)

    ahi2 <- ahi^2
    ahi3 <- ahi^3
    a12 <- a1^2
    a13 <- a1^3
    constant1 <- fa1$f - falo$f - galo*a1
    constant2 <- fahi$f - falo$f - galo*ahi
    scalar <- 1/(ahi2*a12*(a1 - ahi))
    a <- scalar * (ahi2 * constant1 - a12 * constant2)
    b <- scalar * (-ahi3 * constant1 + a13 * constant2)
    term <- suppressWarnings(sqrt(b^2 -3*a*galo))
    if(term < 0 || is.na(term)) term <- 0
    a <- (-b + term)/(3*a)

    if(a > ahi || a < alo) a <- (ahi + alo)/2
    # cat("\n", alo, a, ahi, "\n")

    return(a)

  } else {

    # cat(crayon::red("\n", "alo = ", alo, a1, "ahi = ", ahi, "\n"))

    return(a1)

  }

  # if(interpolation == "cubic") {
