#### Derivative wrt dnorm ####

f3 <- function(x, y) {

  mu <- x[1]
  sd <- x[2]
  d <- dnorm(y, mu, sd)
  return(d)

}

g3 <- function(x, y) {

  mu <- x[1]
  sd <- x[2]
  d <- dnorm(y, mu, sd)
  dmu <- (y-mu)*d/sd^2
  dsd <- ((y-mu)^2-sd^2)*d/sd^3
  g <- c(dmu, dsd)

  return(g)

}

