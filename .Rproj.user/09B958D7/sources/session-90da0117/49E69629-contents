#### Restriction: X'X = diag(1) (Oblique) ####
projection <- function(g, X, ...) {

  p <- length(X)
  X <- matrix(X, sqrt(p), sqrt(p))
  g <- matrix(g, sqrt(p), sqrt(p))
  rg <- c(g - X %*% diag(diag(t(X) %*% g)))

  return(rg)

}
retraction <- function(X, t, V, ...) {

  p <- length(X)
  X <- matrix(X, sqrt(p), sqrt(p))
  V <- matrix(V, sqrt(p), sqrt(p))
  X <- X + t*V
  X <- c(X %*% (diag(1/sqrt(diag(t(X) %*% X)))))

  return(X)

}

