#### Restriction: sum(X) = 1 and X > 0 (Multinomial manifold) ####
projection <- function(g, X, ...) {

  Xegrad <- X * g
  lambda <- -sum(Xegrad)  # Row vector of length m.
  rg <- Xegrad + lambda * X  # This is in the tangent space.

  return(rg)

}
retraction <- function(X, t, V, ...) {

  alpha <- sum(V) # Row vector of length m.
  V <- V - alpha * X
  # nrm <- M.norm(X, V)
  # V <- V / nrm

  X <- X + t*V
  Y <- X * exp(t * (V / X)) # Based on mapping for positive scalars.
  Y <- Y / sum(Y)  # Projection onto the constraint set.

  # For numerical reasons, so that we avoid entries going to zero:
  X <- pmax(Y, .Machine$double.eps)

  return(X)

}

