#### Restriction: X'X = 1 (Unit sphere) ####
projection <- function(g, X, ...) {

  I <- diag(length(c(X)))
  rg <- (I - X %*% t(X)) %*% g

  return(rg)

}
retraction <- function(X, t, V, ...) {

  X <- X + t*V
  X <- X / sqrt(sum(X*X))

  return(X)

}

