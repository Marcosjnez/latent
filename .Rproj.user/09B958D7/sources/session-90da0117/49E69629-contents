# Least-squares problem with different restrictions #

set.seed(373662)
set.seed(2025)
n <- 100
p <- 3+1
predictors <- cbind(1, replicate(p-1, rnorm(n)))
X <- matrix(runif(p, 0, 3), ncol = 1)
X[1] <- 1
X[2] <- -0.2
X[3] <- 0.3
X[4] <- 0.3
Y <- predictors %*% X + rnorm(n, 0, 0.1)

# Objective and gradient for the least-squares problem:
fg <- function(X, f = TRUE, g = FALSE, h = FALSE, ...) {

  res <- Y - predictors %*% X

  if(f) {
    f <- sum(res*res)
  } else {
    f = NULL
  }

  if(g) {
    g <-  -2 * t(predictors) %*% res
    rg <- projection(g, X, ...)
  } else {
    g <- rg <- NULL
  }

  if(h) {
    h <- 2 * t(predictors) %*% predictors
  } else {
    h <- NULL
  }

  return(list(f = f, g = g, rg = rg, h = h))

}

#### Restriction: X'X = I (Orthogonal) ####
symm <- function(X) (X + t(X)) / 2
projection <- function(g, X, ...) {

  p <- length(X)
  X <- matrix(X, sqrt(p), sqrt(p))
  g <- matrix(g, sqrt(p), sqrt(p))
  Lambda <- symm(X %*% t(g))
  rg <- c(g - Lambda %*% X)

  return(rg)

}
retraction <- function(X, t, V, ...) {

  p <- length(X)
  X <- matrix(X, sqrt(p), sqrt(p))
  V <- matrix(V, sqrt(p), sqrt(p))
  X <- X + t*V
  X <- c(qr.Q(qr(X)))

  return(X)

}

