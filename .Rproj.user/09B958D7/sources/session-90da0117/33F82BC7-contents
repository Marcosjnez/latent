# Orthogonal rotation + equalities
library(bifactor)
retr_fix <- function(L_aug, X, target) {

  cols <- which(colSums(target != 0) > 0)
  Y <- X[, cols]
  for(i in 1:length(cols)) {
    rows <- which(target[, cols[i]] != 0)
    B <- cbind(t(L_aug[rows, , drop = FALSE]), Y[, 1:i])
    R <- crossprod(B)
    R[ncol(B), 1:ncol(B)] <- R[1:ncol(B), ncol(B)] <- 0; R[ncol(B), ncol(B)] <- 1
    R[ncol(B), 1:length(rows)] <- R[1:length(rows), ncol(B)] <- target[rows, cols[i]]
    Q <- qr.Q(qr(B))
    x <- solve(t(B) %*% B) %*% t(B) %*% Q
    r <- x %*% chol(R)
    Xa <- B %*% r
    # if(sum(Xa[, ncol(B)] * B[, 1]) = )
    Y[, i] <- -Xa[, ncol(B)]
  }

  Y <- cbind(X[, -cols], Y)

  return(Y)

}
X <- random_oblq(6, 6)
retr_fix <- function(L_aug, X, target) {

  cols <- which(colSums(target != 0) > 0)
  Y <- X[, cols]
  for(i in 1:length(cols)) {
    rows <- which(target[, cols[i]] != 0)
    n_rows <- length(rows)
    B <- cbind(t(L_aug[rows, , drop = FALSE]), X[, 1:3], Y[, i])
    R <- crossprod(B)
    R[ncol(B), 1:(ncol(B)-1)] <- R[1:(ncol(B)-1), ncol(B)] <- 0; #R[ncol(B), ncol(B)] <- 1
    R[ncol(B), 1:length(rows)] <- R[1:length(rows), ncol(B)] <- target[rows, cols[i]]
    R[(n_rows+1):(n_rows+3), ncol(B)] <- R[ncol(B), (n_rows+1):(n_rows+3)] <- 0
    Q <- qr.Q(qr(B))
    x <- solve(t(B) %*% B) %*% t(B) %*% Q
    r <- x %*% chol(R)
    Xa <- B %*% r
    # if(sum(Xa[, ncol(B)] * B[, 1]) = )
    Y[, i] <- -Xa[, ncol(B)]
  }

  Y <- cbind(X[, -cols], Y)

  return(Y)

}
