# Gram Schmidt process:
gram <- function(V, L, target) {

  n <- nrow(V)
  k <- ncol(V)
  U <- matrix(0, n, k)
  indexes <- apply(target, MARGIN = 2, \(x) x != 0, simplify = FALSE)
  correction <- sqrt(1 - colSums(target^2))
  U[indexes[[1]], 1] <- target[indexes[[1]], 1]
  U[!indexes[[1]], 1] <- V[!indexes[[1]], 1] / sqrt(sum(V[!indexes[[1]], 1]^2))*correction[1]

  for(i in 2:k) {

    U[, i] <- V[, i]
    U[indexes[[i]], i] <- target[indexes[[i]], i]

    for(j in 1:(i-1)) {

      U[!indexes[[i]], i] <- U[!indexes[[i]], i] -
        sum(U[!indexes[[i]], j]*U[!indexes[[i]], i]) / sum(U[!indexes[[i]], j]^2) * U[!indexes[[i]], j]

    }

    # U[, i] <- U[, i] / sqrt(sum(U[, i]^2))
    # U[indexes[[i]], i] <- target[indexes[[i]], i]
    U[!indexes[[i]], i] <- U[!indexes[[i]], i] / sqrt(sum(U[!indexes[[i]], i]^2))*correction[i]

  }

  return(U)

}

