# Oblique rotation:
retraction_oblq <- function(t, V, X) {

  X <- X + t*V
  # Z <- X
  X_oblq <- X %*% (diag(1/sqrt(diag(t(X) %*% X))))
  # X_oblq[, 4:6] <- Z[, 4:6]

  return(X_oblq)

}
projection_oblq <- function(G, X) {

  G_proj <- G - X %*% diag(diag(t(X) %*% G))

  return(G_proj)

}

# Orthogonal rotation:
retraction_orth <- function(t, V, X) {

  X <- X + t*V
  UDV <- svd(X)
  X_orth <- UDV$u %*% t(UDV$v)

  return(X_orth)

}
retraction_orth <- function(t, V, X) {

  X <- X + t*V
  X_orth <- qr.Q(qr(X))

  return(X_orth)

}
projection_orth <- function(G, X) {

  Y <- symm(X %*% t(G))
  G_proj <- (G - Y %*% X)

  return(G_proj)

}
