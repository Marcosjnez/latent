\emph{Proof}. The tangent space of $\mathcal{POB}(k, q)$ at $\mathbf{X} \in \mathcal{POB}(k, q)$ is the kernel of (\ref{defining_f}),
\begin{equation} \label{tangent_spc}
\begin{split}
\mathcal{T}_\mathbf{X}\mathcal{POB}(k, q) &= \{\mathbf{Z} \in \mathbb{R}^{n \times n}: \mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X} + 
2\mathbf{P} \text{diag}(\mathbf{X}^\top \mathbf{Z})\mathbf{P} - \mathbf{P}(\mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X}) \mathbf{P} = \mathbf{0} \} \\
&= \{\mathbf{Z} \in \mathbb{R}^{n \times n}: \mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X} = \mathbf{P}(\mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X}) \mathbf{P} \},
\end{split}
\end{equation}
where the term $2\mathbf{P} \text{diag}(\mathbf{X}^\top \mathbf{Z})\mathbf{P}$ vanished because the diagonal of $\mathbf{X}^\top\mathbf{Z}$ must be zero to satisfy the equation.

Note that $\mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X} = \mathbf{0}$ implies that $\mathbf{X}^\top \mathbf{Z}$ is symmetric (and off-diagonal) in the first $k$ rows and columns and skew-symmetric in the remaining entries of the matrix. Let $\text{sym}(\mathbf{X}) = (\mathbf{X} + \mathbf{X}^\top)/2$ and $\text{skew}(\mathbf{X}) = (\mathbf{X} - \mathbf{X}^\top)/2$ such that any matrix can be written in terms of the sum of a symmetric and skew symmetric part. Using this decomposition, we can also define the tangent space of $\mathcal{POB}$ as
$$
\begin{aligned}
\mathcal{T}_\mathbf{X}\mathcal{POB}(k, m) &= \left\{\mathbf{Z}: \mathbf{X}^\top \mathbf{Z} = \mathbf{P} (\mathbf{X}^\top \mathbf{Z} + \mathbf{Z}^\top \mathbf{X}) \mathbf{P} - \mathbf{Z}^\top \mathbf{X} \right\}, \\
&= \left\{ \mathbf{Z}: \mathbf{Z} = \mathbf{X}^{-\top} \left( \text{sym}(\mathbf{X}^\top \mathbf{Z}) + \text{skew}(\mathbf{X}^\top \mathbf{Z}) \right) \right\}.
\end{aligned}
$$
On the other hand, the normal space of $\mathcal{T}_\mathbf{X}\mathcal{POB}(k, q)$ is
$$
\mathcal{N}_{\mathbf{X}} \mathcal{POB}(k, q) = \left\{\mathbf{N} \in \mathbb{R}^{n \times n}: \langle \mathbf{Z}, \mathbf{N} \rangle = \mathbf{0} \text{ for any } \mathbf{Z} \in \mathcal{T}_\mathbf{X}\mathcal{POB}(k, q) \right\}.
$$

Considering that the term $\text{sym}(\mathbf{X}^\top \mathbf{Z}) + \text{skew}(\mathbf{X}^\top \mathbf{Z})$ is off-diagonal in the first $k$ rows and columns and skew-symmetric elsewhere, it follows that its orthogonal complement is a zero-diagonal matrix in the first $k$ rows and columns and symmetric elsewhere. Therefore, we can express the normal space as
$$
\begin{aligned}
\mathcal{N}_{\mathbf{X}} \mathcal{POB} = \left\{\mathbf{N}: \mathbf{N} = \mathbf{XA}, \mathbf{A} \in \mathcal{DS}(k, q) \right\}, 
\end{aligned}
$$

Substituting $\text{grad} \tilde{f}(\mathbf{X})_\perp$ in (\ref{orth_compl}) with the previous parametrization of the normal space, the Riemannian gradient becomes
$$
\text{grad} f(\mathbf{X}) = \text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA}.
$$ 

Substituting $\mathbf{Z}$ in (\ref{tangent_spc}) by this new parametrization, we get
$$
\mathbf{X}^\top (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA}) + (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA})^\top \mathbf{X} = \mathbf{P} (\mathbf{X}^\top (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA}) \mathbf{P} + \mathbf{P} (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA})^\top \mathbf{X}) \mathbf{P}.
$$
Notice that the equation $\mathbf{X}^\top (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA}) = -(\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA})^\top \mathbf{X}$ automatically satisfies $\mathbf{P} \mathbf{X}^\top (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA}) \mathbf{P} = -\mathbf{P} (\text{grad}\tilde{f}(\mathbf{X}) - \mathbf{XA})^\top \mathbf{X} \mathbf{P}$. Therefore, we may just consider solving the former for $\mathbf{A} \in \mathcal{DS}(k, q)$, which leads to the following lyapunov equation
\begin{equation} \label{lyap}
\mathbf{Q} = \mathbf{X}^\top \mathbf{XA} + \mathbf{A} \mathbf{X}^\top \mathbf{X},
\end{equation}
where $\mathbf{Q} := \mathbf{X}^\top \text{grad}\tilde{f}(\mathbf{X}) + \text{grad}\tilde{f}(\mathbf{X})^\top \mathbf{X}$.

Notice that $\mathbf{X}^\top\mathbf{XA} = \mathbf{X}^\top\mathbf{X}(\mathbf{A} + \text{diag}(\mathbf{PAP}) - \mathbf{PAP})$ for any $\mathbf{A} \in \mathcal{Dsym(k, q)}$. To find a solution for $A$ in (\ref{lyap}) that comply with the equation for the tangent space, we may first substitute $\mathbf{A}$ for a dense matrix $\boldsymbol{\Lambda}$, and then switch to zero the off-diagonal elements corresponding to the oblique block of factors. Such a solution satisfies the defining equation for the tangent space and should correspond to $\mathbf{A}$.

This route greatly simplifies the solution because it allows us to exploit the fact that $\mathbf{Q}$, $\mathbf{X}^\top\mathbf{X}$, and $\mathbf{A}$ are all symmetric. Let $\mathbf{V}$ and $\mathbf{D}$ be the eigenvectors and diagonal matrix of eigenvalues of $\mathbf{X}^\top \mathbf{X}$, respectively. Then, 
$$
\begin{split}
\mathbf{V}^\top \mathbf{QV} &= \mathbf{V}^\top \mathbf{X}^\top \mathbf{X}\boldsymbol{\Lambda}\mathbf{V} + \mathbf{V}^\top \boldsymbol{\Lambda}\mathbf{X}^\top\mathbf{XV} \\
&= (\mathbf{V}^\top \mathbf{X}^\top \mathbf{XV}) \mathbf{V}^\top \boldsymbol{\Lambda}\mathbf{V} + \mathbf{V}^\top \boldsymbol{\Lambda}\mathbf{V} (\mathbf{V}^\top \mathbf{X}^\top\mathbf{XV}) \\
&= \mathbf{DV}^\top \boldsymbol{\Lambda}\mathbf{V} + \mathbf{V}^\top \boldsymbol{\Lambda}\mathbf{VD}.
\end{split}
$$
We now want to rewrite the left hand side of this expression so that the resulting matrix is similar to $\boldsymbol{\Lambda}$ (ie., it has the same eigenvalues). Let $\mathbf{1}$ be an n-dimensional vector of ones and $\mathbf{d}$ be the vector of eigenvalues of $\mathbf{X}^\top \mathbf{X}$. Then,
$$
\frac{\mathbf{V}^\top \mathbf{QV}}{\mathbf{1} \mathbf{d}^\top + \mathbf{d} \mathbf{1}^\top} = \mathbf{V}^\top \boldsymbol{\Lambda}\mathbf{V}, \quad \text{and}
$$
$$
\boldsymbol{\Lambda} = \mathbf{V}\left( \frac{\mathbf{V}^\top \mathbf{QV}}{\mathbf{1} \mathbf{d}^\top + \mathbf{d} \mathbf{1}^\top} \right) \mathbf{V}^\top.
$$
Finally, let $I$ be an operator that sets to zero the off-diagonal elements corresponding to the oblique blocks. Then,
$$
\mathbf{A} = I \circ \boldsymbol{\Lambda}.
$$

